<?xml version="1.0" encoding="ISO-8859-1"?>
<!--
  XScreenSaver configuration descriptor for the Flying Air Fryers hack.
  Installed to /usr/share/xscreensaver/config/ by `sudo make install`.
-->
<screensaver name="airfryer" _label="Flying Air Fryers">
  <command arg="-root"/>

  <number id="speed" type="slider" arg="-speed %"
          _label="Speed" _low-label="Slow" _high-label="Fast"
          low="10" high="500" default="100"/>

  <_description>
Flying air fryers with chicken nuggets.
  </_description>
</screensaver>
